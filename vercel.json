{
  "buildCommand": "cd warm-wishes && npm ci && npm run build",
  "outputDirectory": "warm-wishes/dist/warm-wishes/browser",
  "installCommand": "echo 'skip root install'",
  "framework": null,
  "env": {
    "NODE_VERSION": "24.13.0"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
