{
  "buildCommand": "cd warm-wishes && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "warm-wishes/dist/warm-wishes/browser",
  "installCommand": "echo 'skipping root install'",
  "framework": null,
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
